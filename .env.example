# ===== Application =====
SERVER_PORT=8080

# ===== Database =====
# Default: embedded H2 (no installation needed)
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/devfest;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# To use PostgreSQL instead (start it with: docker compose up -d db),
# comment the H2 lines above and uncomment these:
#SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/devfest
#SPRING_DATASOURCE_USERNAME=devfest
#SPRING_DATASOURCE_PASSWORD=devfest

# ===== Docker Compose (PostgreSQL container) =====
POSTGRES_DB=devfest
POSTGRES_USER=devfest
POSTGRES_PASSWORD=devfest
